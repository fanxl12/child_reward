# ============================================
# 儿童表现记录系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置
# ============================================

# 应用配置
DEBUG=true

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@192.168.9.2:5432/child_reward
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@192.168.9.2:5432/child_reward

# JWT 密钥（生产环境请使用强密钥）
SECRET_KEY=your-very-secret-key-change-this-in-production

# 微信小程序配置（替换为实际值）
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=your-wechat-app-secret
