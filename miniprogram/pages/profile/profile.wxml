<!--
  个人中心页
-->
<view class="page-profile">
  <!-- 用户信息卡片 -->
  <view class="profile-header">
    <block wx:if="{{isLoggedIn}}">
      <view class="profile-avatar">
        <image wx:if="{{userInfo.avatar_url}}" src="{{userInfo.avatar_url}}" mode="aspectFill" />
        <text wx:elif="{{userInfo.nickname}}" class="avatar-text">{{userInfo.nickname[0]}}</text>
        <text wx:elif="{{userInfo.username}}" class="avatar-text">{{userInfo.username[0]}}</text>
        <text wx:else class="avatar-text">?</text>
      </view>
      <view class="profile-info">
        <text wx:if="{{userInfo.nickname}}" class="profile-name">{{userInfo.nickname}}</text>
        <text wx:elif="{{userInfo.username}}" class="profile-name">{{userInfo.username}}</text>
        <text wx:else class="profile-name">用户</text>
        <text wx:if="{{userInfo.username}}" class="profile-id">@{{userInfo.username}}</text>
      </view>
    </block>
    <block wx:else>
      <view class="profile-avatar" bindtap="goToLogin">
        <text class="avatar-text">?</text>
      </view>
      <view class="profile-info" bindtap="goToLogin">
        <text class="profile-name">未登录</text>
        <text class="profile-id">点击登录</text>
      </view>
    </block>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-title">管理</view>
    <view class="menu-item" bindtap="goToChildren">
      <text class="menu-icon">👶</text>
      <text class="menu-label">儿童管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToRewardShop">
      <text class="menu-icon">🏪</text>
      <text class="menu-label">奖励商品设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">账户</view>
    <view class="menu-item" bindtap="onEditProfile">
      <text class="menu-icon">✏️</text>
      <text class="menu-label">修改昵称</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onEditUsername">
      <text class="menu-icon">👤</text>
      <text class="menu-label">修改用户名</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onChangePassword">
      <text class="menu-icon">🔑</text>
      <text class="menu-label">修改密码</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">其他</view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 登录 / 退出登录 -->
  <view wx:if="{{!isLoggedIn}}" class="logout-btn" style="background-color: #FF7B6B; color: #fff;" bindtap="goToLogin">登录</view>
  <view wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="onLogout">退出登录</view>

  <!-- 修改昵称弹窗 -->
  <view class="modal-mask" wx:if="{{showEditNickname}}" bindtap="onCloseEdit">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">修改昵称</text>
        <view class="modal-close" bindtap="onCloseEdit">✕</view>
      </view>
      <view class="form-item" style="padding: 0 8rpx;">
        <input class="form-input" placeholder="请输入新昵称" value="{{newNickname}}" bindinput="onNicknameInput" />
      </view>
      <view class="modal-footer">
        <view class="btn-secondary" bindtap="onCloseEdit">取消</view>
        <view class="btn-primary" bindtap="onSaveNickname">保存</view>
      </view>
    </view>
  </view>

  <!-- 修改用户名弹窗 -->
  <view class="modal-mask" wx:if="{{showEditUsername}}" bindtap="onCloseEditUsername">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">修改用户名</text>
        <view class="modal-close" bindtap="onCloseEditUsername">✕</view>
      </view>
      <view class="form-item" style="padding: 0 8rpx;">
        <input class="form-input" placeholder="3-50 个字符，用于登录识别" value="{{newUsername}}" bindinput="onUsernameInput" />
      </view>
      <view class="modal-footer">
        <view class="btn-secondary" bindtap="onCloseEditUsername">取消</view>
        <view class="btn-primary" bindtap="onSaveUsername">保存</view>
      </view>
    </view>
  </view>

  <!-- 修改密码弹窗 -->
  <view class="modal-mask" wx:if="{{showChangePassword}}" bindtap="onCloseChangePassword">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">{{hasPassword ? '修改密码' : '设置密码'}}</text>
        <view class="modal-close" bindtap="onCloseChangePassword">✕</view>
      </view>
      <view wx:if="{{hasPassword}}" class="form-item" style="padding: 0 8rpx;">
        <input password class="form-input" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPasswordInput" />
      </view>
      <view class="form-item" style="padding: 0 8rpx;">
        <input password class="form-input" placeholder="请输入新密码（至少 6 位）" value="{{newPassword}}" bindinput="onNewPasswordInput" />
      </view>
      <view class="form-item" style="padding: 0 8rpx;">
        <input password class="form-input" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>
      <view class="modal-footer">
        <view class="btn-secondary" bindtap="onCloseChangePassword">取消</view>
        <view class="btn-primary" bindtap="onSavePassword">{{hasPassword ? '保存' : '设置'}}</view>
      </view>
    </view>
  </view>
</view>
