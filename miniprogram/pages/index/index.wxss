/* 首页 - 日历视图样式 */

.page-index {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ---- 顶部栏 ---- */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

.child-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.child-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.child-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.child-info {
  display: flex;
  flex-direction: column;
}

.child-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.child-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.coin-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.2);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
}

.coin-emoji {
  font-size: 32rpx;
}

.coin-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ---- 月份导航 ---- */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  padding: 32rpx 0 16rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow-sm);
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

.nav-btn:active {
  background: var(--color-border);
}

.month-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.month-year {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.month-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ---- 月度统计 ---- */
.month-stats {
  display: flex;
  justify-content: space-around;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-md);
  min-width: 120rpx;
}

.stat-good {
  background: var(--color-success-light);
}

.stat-bad {
  background: var(--color-danger-light);
}

.stat-coin {
  background: var(--color-coin-light);
}

.stat-deduct {
  background: #F5F3FF;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* ---- 日历卡片 ---- */
.calendar-card {
  margin: 0 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 24rpx;
}

.week-header {
  display: flex;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-hint);
  padding-bottom: 16rpx;
  font-weight: 500;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 6rpx;
}

.calendar-cell {
  width: calc((100% - 36rpx) / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: var(--radius-sm);
  transition: all 0.15s ease;
}

.calendar-cell:active:not(.cell-empty) {
  background: var(--color-bg-section);
  transform: scale(0.95);
}

.cell-empty {
  opacity: 0;
}

.cell-day {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.cell-today {
  background: var(--color-primary);
  border-radius: var(--radius-sm);
}

.cell-today:not(.cell-good):not(.cell-bad) {
  border-radius: 50%;
}

.cell-today .cell-day {
  color: #FFFFFF;
  font-weight: 700;
}

.cell-good {
  background: var(--color-success-light);
}

.cell-good .cell-day {
  color: var(--color-success);
}

.cell-bad {
  background: var(--color-danger-light);
}

.cell-bad .cell-day {
  color: var(--color-danger);
}

.cell-dot {
  font-size: 18rpx;
  margin-top: 2rpx;
  line-height: 1;
}

.cell-coins {
  font-size: 18rpx;
  color: var(--color-coin-dark);
  font-weight: 600;
  margin-top: 2rpx;
  margin-bottom: 4rpx;
  line-height: 1;
}

/* ---- 悬浮按钮 ---- */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-primary);
  z-index: 100;
}

.fab-button:active {
  transform: scale(0.92);
  background: var(--color-primary-dark);
}

.fab-icon {
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}

/* ---- 弹窗公共样式 ---- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx;
  max-height: 70vh;
  animation: slideUp 0.3s ease;
  display: flex;
  flex-direction: column;
}

.modal-large {
  max-height: 85vh;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-hint);
  font-size: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  justify-content: flex-end;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--color-border);
}

/* ---- 儿童选择列表 ---- */
.child-list {
  max-height: 50vh;
  overflow-y: auto;
}

.child-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 16rpx;
  border-radius: var(--radius-md);
  margin-bottom: 8rpx;
  transition: background 0.15s;
}

.child-option:active {
  background: var(--color-bg-section);
}

.child-option.selected {
  background: var(--color-primary);
  background: rgba(255, 123, 107, 0.1);
}

.child-avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-weight: 600;
  font-size: 26rpx;
}

.child-option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.child-option-name {
  font-size: 30rpx;
  font-weight: 500;
}

.child-option-coins {
  font-size: 24rpx;
  color: var(--color-coin-dark);
}

.check-mark {
  color: var(--color-primary);
  font-size: 36rpx;
  font-weight: 700;
}

/* ---- 表单样式 ---- */
.form-section {
  padding: 0 8rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-input {
  padding: 16rpx 24rpx;
  background: var(--color-bg-section);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 24rpx;
  background: var(--color-bg-section);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 评价选择器 */
.rating-selector {
  display: flex;
  gap: 24rpx;
}

.rating-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-bg-section);
  border-radius: var(--radius-md);
  border: 3rpx solid transparent;
  font-size: 28rpx;
  transition: all 0.2s;
}

.rating-emoji {
  font-size: 36rpx;
}

.rating-active-good {
  background: var(--color-success-light);
  border-color: var(--color-success);
  color: var(--color-success);
}

.rating-active-bad {
  background: var(--color-danger-light);
  border-color: var(--color-danger);
  color: var(--color-danger);
}

/* 奖惩明细 */
.reward-list {
  margin-bottom: 16rpx;
}

.reward-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.reward-entry-type {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.type-reward {
  background: var(--color-success);
}

.type-punishment {
  background: var(--color-danger);
}

.reward-entry-desc {
  flex: 1;
  font-size: 26rpx;
}

.reward-entry-coins {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-coin-dark);
}

.reward-entry-del {
  color: var(--color-text-hint);
  padding: 8rpx;
  font-size: 24rpx;
}

/* 添加奖惩行 */
.add-reward-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reward-type-toggle {
  display: flex;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 2rpx solid var(--color-border);
}

.toggle-item {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  background: var(--color-bg-section);
}

.toggle-active-good {
  background: var(--color-success);
  color: #FFFFFF;
}

.toggle-active-bad {
  background: var(--color-danger);
  color: #FFFFFF;
}

.reward-desc-input {
  flex: 1;
  padding: 8rpx 16rpx;
  background: var(--color-bg-section);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
}

.reward-coins-input {
  width: 80rpx;
  padding: 8rpx 12rpx;
  background: var(--color-bg-section);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  text-align: center;
}

.btn-add-reward {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 32rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close {
  font-size: 40rpx;
  color: var(--color-text-hint);
  padding: 0 8rpx;
}

.form-item {
  padding: 24rpx 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg-section);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  line-height: 80rpx;
}

.form-input::placeholder {
  color: var(--color-text-hint);
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 32rpx;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  box-shadow: var(--shadow-primary);
}

.btn-secondary {
  background: var(--color-bg-section);
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
}
