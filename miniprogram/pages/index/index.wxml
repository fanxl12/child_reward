<!--
  首页 - 日历视图
  展示儿童每月表现日历
-->
<view class="page-index">
  <!-- 顶部：儿童选择 & 奖励币 -->
  <view class="header-bar">
    <view class="child-selector" bindtap="onSwitchChild">
      <view class="child-avatar">
        <image wx:if="{{currentChild.avatar_url}}" src="{{currentChild.avatar_url}}" mode="aspectFill" />
        <text wx:else class="avatar-placeholder">{{currentChild.name[0] || '?'}}</text>
      </view>
      <view class="child-info">
        <text class="child-name">{{currentChild.name || '请选择儿童'}}</text>
        <text class="child-hint">点击切换 ▾</text>
      </view>
    </view>
    <view class="coin-display" bindtap="onViewCoins">
      <text class="coin-emoji">🪙</text>
      <text class="coin-amount">{{currentChild.coin_balance || 0}}</text>
    </view>
  </view>

  <!-- 月份导航 -->
  <view class="month-nav">
    <view class="nav-btn" bindtap="onPrevMonth">
      <text>‹</text>
    </view>
    <view class="month-title" bindtap="onPickYearMonth">
      <text class="month-year">{{year}}年</text>
      <text class="month-name">{{monthText}}</text>
    </view>
    <view class="nav-btn" bindtap="onNextMonth">
      <text>›</text>
    </view>
  </view>

  <!-- 月度统计 -->
  <view class="month-stats">
    <view class="stat-item stat-good">
      <text class="stat-value">{{stats.goodDays}}</text>
      <text class="stat-label">好表现</text>
    </view>
    <view class="stat-item stat-bad">
      <text class="stat-value">{{stats.badDays}}</text>
      <text class="stat-label">需改进</text>
    </view>
    <view class="stat-item stat-coin">
      <text class="stat-value">+{{stats.totalEarned}}</text>
      <text class="stat-label">获得币</text>
    </view>
    <view class="stat-item stat-deduct">
      <text class="stat-value">-{{stats.totalDeducted}}</text>
      <text class="stat-label">扣除币</text>
    </view>
  </view>

  <!-- 日历网格 -->
  <view class="calendar-card">
    <!-- 星期表头 -->
    <view class="week-header">
      <text class="week-day" wx:for="{{weekDays}}" wx:key="index">{{item}}</text>
    </view>

    <!-- 日期格子 -->
    <view class="calendar-grid">
      <view wx:for="{{calendarDays}}" wx:key="index"
        class="calendar-cell {{item.empty ? 'cell-empty' : ''}} {{item.isToday ? 'cell-today' : ''}} {{item.rating === 'good' ? 'cell-good' : ''}} {{item.rating === 'bad' ? 'cell-bad' : ''}}"
        bindtap="onDayTap" data-item="{{item}}">
        <text class="cell-day" wx:if="{{!item.empty}}">{{item.day}}</text>
        <view class="cell-dot" wx:if="{{item.rating}}">
          <text wx:if="{{item.rating === 'good'}}">⭐</text>
          <text wx:if="{{item.rating === 'bad'}}">💔</text>
        </view>
        <text class="cell-coins" wx:if="{{item.coins}}">
          {{item.coins > 0 ? '+' : ''}}{{item.coins}}
        </text>
      </view>
    </view>
  </view>

  <!-- 添加记录按钮 -->
  <view class="fab-button" bindtap="onAddRecord">
    <text class="fab-icon">+</text>
  </view>

  <!-- 儿童选择弹窗 -->
  <view class="modal-mask" wx:if="{{showChildPicker}}" bindtap="onCloseChildPicker">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">选择儿童</text>
        <view class="modal-close" bindtap="onCloseChildPicker">✕</view>
      </view>
      <view class="child-list">
        <view class="child-option {{item.id === currentChild.id ? 'selected' : ''}}" wx:for="{{children}}" wx:key="id"
          bindtap="onSelectChild" data-child="{{item}}">
          <view class="child-avatar-sm">
            <text>{{item.name[0]}}</text>
          </view>
          <view class="child-option-info">
            <text class="child-option-name">{{item.name}}</text>
            <text class="child-option-coins">🪙 {{item.coin_balance}}</text>
          </view>
          <text class="check-mark" wx:if="{{item.id === currentChild.id}}">✓</text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn-secondary btn-small" bindtap="onManageChildren">管理儿童</view>
      </view>
    </view>
  </view>

  <!-- 添加记录弹窗 -->
  <view class="modal-mask" wx:if="{{showAddRecord}}" bindtap="onCloseAddRecord">
    <view class="modal-content modal-large" catchtap>
      <view class="modal-header">
        <text class="modal-title">记录今日表现</text>
        <view class="modal-close" bindtap="onCloseAddRecord">✕</view>
      </view>

      <scroll-view class="modal-body" scroll-y>
        <view class="form-section">
          <!-- 日期选择 -->
          <view class="form-item">
            <text class="form-label">日期</text>
            <picker mode="date" value="{{recordForm.date}}" bindchange="onDateChange">
              <view class="form-input">{{recordForm.date}}</view>
            </picker>
          </view>

          <!-- 总体评价 -->
          <view class="form-item">
            <text class="form-label">总体评价</text>
            <view class="rating-selector">
              <view class="rating-option {{recordForm.rating === 'good' ? 'rating-active-good' : ''}}"
                bindtap="onRatingChange" data-rating="good">
                <text class="rating-emoji">⭐</text>
                <text>表现好</text>
              </view>
              <view class="rating-option {{recordForm.rating === 'bad' ? 'rating-active-bad' : ''}}"
                bindtap="onRatingChange" data-rating="bad">
                <text class="rating-emoji">💔</text>
                <text>需改进</text>
              </view>
            </view>
          </view>

          <!-- 评语 -->
          <view class="form-item">
            <text class="form-label">评语</text>
            <textarea class="form-textarea" placeholder="写下今天的评语..." value="{{recordForm.comment}}"
              bindinput="onCommentInput" maxlength="500" />
          </view>

          <!-- 奖惩明细 -->
          <view class="form-item">
            <text class="form-label">奖惩明细</text>
            <view class="reward-list">
              <view class="reward-entry" wx:for="{{recordForm.rewards}}" wx:key="index">
                <view class="reward-entry-type {{item.type === 'reward' ? 'type-reward' : 'type-punishment'}}">
                  {{item.type === 'reward' ? '奖' : '罚'}}
                </view>
                <text class="reward-entry-desc">{{item.description}}</text>
                <text class="reward-entry-coins">{{item.type === 'reward' ? '+' : '-'}}{{item.coins}}🪙</text>
                <view class="reward-entry-del" bindtap="onDeleteRewardEntry" data-index="{{index}}">✕</view>
              </view>
            </view>

            <!-- 添加奖惩 -->
            <view class="add-reward-row">
              <view class="reward-type-toggle">
                <view class="toggle-item {{newReward.type === 'reward' ? 'toggle-active-good' : ''}}"
                  bindtap="onNewRewardType" data-type="reward">奖励</view>
                <view class="toggle-item {{newReward.type === 'punishment' ? 'toggle-active-bad' : ''}}"
                  bindtap="onNewRewardType" data-type="punishment">惩罚</view>
              </view>
              <input class="reward-desc-input" placeholder="描述" value="{{newReward.description}}"
                bindinput="onNewRewardDesc" />
              <input class="reward-coins-input" placeholder="币" value="{{newReward.coins}}" bindinput="onNewRewardCoins"
                bindblur="onNewRewardCoins" />
              <view class="btn-add-reward" bindtap="onAddRewardEntry">+</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <view class="btn-secondary" bindtap="onCloseAddRecord">取消</view>
        <view class="btn-primary" bindtap="onSubmitRecord">保存记录</view>
      </view>
    </view>
  </view>

  <!-- 月份选择弹窗 -->
  <view class="modal-mask" wx:if="{{showMonthPicker}}" bindtap="onCloseMonthPicker">
    <view class="modal-content month-picker-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">选择月份</text>
        <view class="modal-close" bindtap="onCloseMonthPicker">✕</view>
      </view>

      <view class="month-picker-body">
        <!-- 年份导航 -->
        <view class="year-nav">
          <view class="year-nav-btn" bindtap="onPickerPrevYear">‹</view>
          <text class="year-text">{{pickerYear}}年</text>
          <view class="year-nav-btn" bindtap="onPickerNextYear">›</view>
        </view>

        <!-- 月份网格 -->
        <view class="month-grid">
          <view wx:for="{{months}}" wx:key="*this"
            class="month-item {{item === month && pickerYear === year ? 'month-active' : ''}}"
            bindtap="onSelectMonth" data-month="{{item}}">
            <text class="month-item-text">{{item}}月</text>
          </view>
        </view>
      </view>

      <view class="month-picker-footer">
        <view class="btn-secondary btn-small" bindtap="onBackToToday">返回本月</view>
      </view>
    </view>
  </view>
</view>