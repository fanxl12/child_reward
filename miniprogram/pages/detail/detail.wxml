<!--
  日期详情页 - 查看/编辑当日表现
-->
<view class="page-detail">
  <!-- 顶部日期卡片 -->
  <view class="date-card {{record.overall_rating === 'good' ? 'date-card-good' : 'date-card-bad'}}">
    <view class="date-info">
      <text class="date-day">{{dateDay}}日</text>
      <view class="date-meta">
        <text class="date-full">{{dateText}}</text>
        <text class="date-weekday">{{weekdayText}}</text>
      </view>
    </view>
    <view class="rating-badge {{record.overall_rating === 'good' ? 'badge-good' : 'badge-bad'}}">
      <text class="rating-icon">{{record.overall_rating === 'good' ? '👍' : '💔'}}</text>
      <text class="rating-text">{{record.overall_rating === 'good' ? '表现好' : '需改进'}}</text>
    </view>
  </view>

  <!-- 评语卡片 -->
  <view class="card" wx:if="{{record.comment}}">
    <text class="card-title">📝 评语：</text>
    <text class="comment-text">{{record.comment}}</text>
  </view>

  <!-- 奖惩明细 -->
  <view class="card" wx:if="{{record.reward_records.length > 0}}">
    <view class="detail-head">
      <text class="card-title">📋 奖惩明细</text>
      <view class="btn-add-detail" bindtap="onOpenAddReward">添加奖惩</view>
    </view>
    <view class="detail-list">
      <view 
        class="detail-item" 
        wx:for="{{record.reward_records}}" 
        wx:key="id"
      >
        <view class="detail-icon {{item.type === 'reward' ? 'icon-reward' : 'icon-punishment'}}">
          {{item.type === 'reward' ? '🏆' : '⚡'}}
        </view>
        <view class="detail-content">
          <text class="detail-desc">{{item.description}}</text>
          <view class="detail-type tag {{item.type === 'reward' ? 'tag-good' : 'tag-bad'}}">
            {{item.type === 'reward' ? '奖励' : '惩罚'}}
          </view>
        </view>
        <text class="detail-coins {{item.type === 'reward' ? 'coins-positive' : 'coins-negative'}}">
          {{item.type === 'reward' ? '+' : '-'}}{{item.coins}} 🪙
        </text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{hasRecord && (!record.reward_records || record.reward_records.length === 0)}}">
    <view class="empty-detail">
      <text class="empty-detail-text">今日暂无奖惩明细</text>
      <view class="btn-add-detail" bindtap="onOpenAddReward">添加第一条</view>
    </view>
  </view>

  <!-- 币数汇总 -->
  <view class="coin-summary">
    <view class="summary-item">
      <text class="summary-label">获得奖励币</text>
      <text class="summary-value coins-positive">+{{record.coins_earned || 0}}</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-label">扣除奖励币</text>
      <text class="summary-value coins-negative">-{{record.coins_deducted || 0}}</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-item">
      <text class="summary-label">净变动</text>
      <text class="summary-value {{netCoins >= 0 ? 'coins-positive' : 'coins-negative'}}">
        {{netCoins >= 0 ? '+' : ''}}{{netCoins}}
      </text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!hasRecord}}">
    <text class="empty-state-icon">📭</text>
    <text class="empty-state-text">该日期暂无记录</text>
    <view class="btn-primary" style="margin-top: 32rpx;" bindtap="onAddRecord">添加记录</view>
  </view>

  <view class="modal-mask" wx:if="{{showAddReward}}" bindtap="onCloseAddReward">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">添加奖惩</text>
        <view class="modal-close" bindtap="onCloseAddReward">✕</view>
      </view>

      <view class="form-item">
        <text class="form-label">类型</text>
        <view class="reward-type-toggle">
          <view class="toggle-item {{newReward.type === 'reward' ? 'toggle-active-good' : ''}}"
            bindtap="onNewRewardType" data-type="reward">奖励</view>
          <view class="toggle-item {{newReward.type === 'punishment' ? 'toggle-active-bad' : ''}}"
            bindtap="onNewRewardType" data-type="punishment">惩罚</view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">描述</text>
        <input class="form-input" placeholder="例如：主动收拾玩具" value="{{newReward.description}}" bindinput="onNewRewardDesc" />
      </view>

      <view class="form-item">
        <text class="form-label">币数</text>
        <input class="form-input" type="number" placeholder="请输入正整数" value="{{newReward.coins}}" bindinput="onNewRewardCoins" bindblur="onNewRewardCoins" />
      </view>

      <view class="modal-footer">
        <view class="btn-secondary" bindtap="onCloseAddReward">取消</view>
        <view class="btn-primary" bindtap="onSubmitAddReward">保存</view>
      </view>
    </view>
  </view>
</view>
